PORT=7002
DATABASE_URL="mysql://ex:ex@localhost:3306/ex"
JWT_SECRET="change-me-in-production-please-use-a-long-random-string"
JWT_EXPIRES_IN="7d"
CORS_ORIGIN="http://localhost:5173"

# 業主 Portal SSO 整合（B4 階段填）
PORTAL_SSO_PUBLIC_KEY=""
PORTAL_SSO_ISSUER=""

# Email
# dev：本地 Mailhog（docker-compose 內建）
SMTP_DEV_HOST=localhost
SMTP_DEV_PORT=1025
SMTP_DEV_FROM="EX 系統 (dev) <noreply@ex.local>"
APP_BASE_URL="http://localhost:5173/EXPO"
# prod：移除 SMTP_DEV_HOST，自動 fallback 到 tenant 的 smtp_settings 表
# 真實密碼建議放 secret store，env 注入：SMTP_PASSWORD_<tenant_id>=...
